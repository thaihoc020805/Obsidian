{
	"nodes":[
		{"id":"9a8d00530767dd26","x":-220,"y":-480,"width":720,"height":820,"type":"text","text":"<svg viewBox=\"0 0 1200 1400\" xmlns=\"http://www.w3.org/2000/svg\">\n  <!-- Title -->\n  <text x=\"600\" y=\"30\" font-size=\"24\" font-weight=\"bold\" text-anchor=\"middle\" fill=\"#333\">\n    Sơ đồ chi tiết luồng hoạt động SSE và Streamable HTTP\n  </text>\n  \n  <!-- SSE Section -->\n  <rect x=\"50\" y=\"60\" width=\"1100\" height=\"600\" fill=\"#f0f8ff\" stroke=\"#4169e1\" stroke-width=\"2\" rx=\"10\"/>\n  <text x=\"600\" y=\"90\" font-size=\"20\" font-weight=\"bold\" text-anchor=\"middle\" fill=\"#4169e1\">\n    SSE (Server-Sent Events)\n  </text>\n  \n  <!-- Client Side -->\n  <rect x=\"80\" y=\"120\" width=\"200\" height=\"500\" fill=\"#e8f4f8\" stroke=\"#2c5282\" stroke-width=\"2\" rx=\"5\"/>\n  <text x=\"180\" y=\"145\" font-size=\"16\" font-weight=\"bold\" text-anchor=\"middle\" fill=\"#2c5282\">Client (Browser)</text>\n  \n  <!-- Server Side -->\n  <rect x=\"920\" y=\"120\" width=\"200\" height=\"500\" fill=\"#fef3e8\" stroke=\"#d97706\" stroke-width=\"2\" rx=\"5\"/>\n  <text x=\"1020\" y=\"145\" font-size=\"16\" font-weight=\"bold\" text-anchor=\"middle\" fill=\"#d97706\">Server</text>\n  \n  <!-- Step 1: Initial Request -->\n  <circle cx=\"180\" cy=\"180\" r=\"20\" fill=\"#3b82f6\"/>\n  <text x=\"180\" y=\"187\" font-size=\"14\" text-anchor=\"middle\" fill=\"white\">1</text>\n  <text x=\"180\" y=\"220\" font-size=\"12\" text-anchor=\"middle\" fill=\"#333\">EventSource API</text>\n  <text x=\"180\" y=\"235\" font-size=\"11\" text-anchor=\"middle\" fill=\"#666\">new EventSource('/stream')</text>\n  \n  <!-- Arrow 1 -->\n  <path d=\"M 280 190 L 920 190\" stroke=\"#3b82f6\" stroke-width=\"2\" marker-end=\"url(#arrowblue)\"/>\n  <text x=\"600\" y=\"180\" font-size=\"12\" text-anchor=\"middle\" fill=\"#3b82f6\">HTTP GET Request</text>\n  <text x=\"600\" y=\"195\" font-size=\"11\" text-anchor=\"middle\" fill=\"#666\">Accept: text/event-stream</text>\n  \n  <!-- Step 2: Server Response -->\n  <circle cx=\"1020\" cy=\"260\" r=\"20\" fill=\"#d97706\"/>\n  <text x=\"1020\" y=\"267\" font-size=\"14\" text-anchor=\"middle\" fill=\"white\">2</text>\n  <text x=\"1020\" y=\"300\" font-size=\"12\" text-anchor=\"middle\" fill=\"#333\">Mở kết nối</text>\n  <text x=\"1020\" y=\"315\" font-size=\"11\" text-anchor=\"middle\" fill=\"#666\">Content-Type: text/event-stream</text>\n  <text x=\"1020\" y=\"330\" font-size=\"11\" text-anchor=\"middle\" fill=\"#666\">Cache-Control: no-cache</text>\n  \n  <!-- Connection established -->\n  <rect x=\"400\" y=\"350\" width=\"400\" height=\"30\" fill=\"#d4edda\" stroke=\"#28a745\" stroke-width=\"1\" rx=\"5\"/>\n  <text x=\"600\" y=\"370\" font-size=\"12\" text-anchor=\"middle\" fill=\"#155724\">Kết nối được giữ mở (Keep-Alive)</text>\n  \n  <!-- Step 3: Server Push Events -->\n  <circle cx=\"1020\" cy=\"420\" r=\"20\" fill=\"#d97706\"/>\n  <text x=\"1020\" y=\"427\" font-size=\"14\" text-anchor=\"middle\" fill=\"white\">3</text>\n  <text x=\"1020\" y=\"460\" font-size=\"12\" text-anchor=\"middle\" fill=\"#333\">Push Events</text>\n  \n  <!-- Multiple events -->\n  <path d=\"M 920 430 L 280 430\" stroke=\"#28a745\" stroke-width=\"2\" marker-end=\"url(#arrowgreen)\" stroke-dasharray=\"5,5\"/>\n  <text x=\"600\" y=\"420\" font-size=\"11\" text-anchor=\"middle\" fill=\"#28a745\">data: {\"message\": \"Event 1\"}\\n\\n</text>\n  \n  <path d=\"M 920 470 L 280 470\" stroke=\"#28a745\" stroke-width=\"2\" marker-end=\"url(#arrowgreen)\" stroke-dasharray=\"5,5\"/>\n  <text x=\"600\" y=\"460\" font-size=\"11\" text-anchor=\"middle\" fill=\"#28a745\">data: {\"message\": \"Event 2\"}\\n\\n</text>\n  \n  <path d=\"M 920 510 L 280 510\" stroke=\"#28a745\" stroke-width=\"2\" marker-end=\"url(#arrowgreen)\" stroke-dasharray=\"5,5\"/>\n  <text x=\"600\" y=\"500\" font-size=\"11\" text-anchor=\"middle\" fill=\"#28a745\">data: {\"message\": \"Event 3\"}\\n\\n</text>\n  \n  <!-- Client receives -->\n  <circle cx=\"180\" cy=\"470\" r=\"20\" fill=\"#3b82f6\"/>\n  <text x=\"180\" y=\"477\" font-size=\"14\" text-anchor=\"middle\" fill=\"white\">4</text>\n  <text x=\"180\" y=\"510\" font-size=\"12\" text-anchor=\"middle\" fill=\"#333\">onmessage handler</text>\n  <text x=\"180\" y=\"525\" font-size=\"11\" text-anchor=\"middle\" fill=\"#666\">Xử lý từng event</text>\n  \n  <!-- SSE Characteristics -->\n  <rect x=\"320\" y=\"550\" width=\"560\" height=\"90\" fill=\"#fff3cd\" stroke=\"#ffc107\" stroke-width=\"1\" rx=\"5\"/>\n  <text x=\"600\" y=\"570\" font-size=\"14\" font-weight=\"bold\" text-anchor=\"middle\" fill=\"#856404\">Đặc điểm SSE:</text>\n  <text x=\"340\" y=\"590\" font-size=\"12\" fill=\"#856404\">• Chỉ một chiều: Server → Client</text>\n  <text x=\"340\" y=\"610\" font-size=\"12\" fill=\"#856404\">• Tự động reconnect khi mất kết nối</text>\n  <text x=\"340\" y=\"630\" font-size=\"12\" fill=\"#856404\">• Dùng HTTP/1.1, giới hạn 6 kết nối/domain</text>\n  \n  <!-- Streamable HTTP Section -->\n  <rect x=\"50\" y=\"700\" width=\"1100\" height=\"650\" fill=\"#f0fff0\" stroke=\"#228b22\" stroke-width=\"2\" rx=\"10\"/>\n  <text x=\"600\" y=\"730\" font-size=\"20\" font-weight=\"bold\" text-anchor=\"middle\" fill=\"#228b22\">\n    Streamable HTTP (HTTP/2+ Streaming)\n  </text>\n  \n  <!-- Client Side -->\n  <rect x=\"80\" y=\"760\" width=\"200\" height=\"550\" fill=\"#e8f4f8\" stroke=\"#2c5282\" stroke-width=\"2\" rx=\"5\"/>\n  <text x=\"180\" y=\"785\" font-size=\"16\" font-weight=\"bold\" text-anchor=\"middle\" fill=\"#2c5282\">Client</text>\n  \n  <!-- Server Side -->\n  <rect x=\"920\" y=\"760\" width=\"200\" height=\"550\" fill=\"#fef3e8\" stroke=\"#d97706\" stroke-width=\"2\" rx=\"5\"/>\n  <text x=\"1020\" y=\"785\" font-size=\"16\" font-weight=\"bold\" text-anchor=\"middle\" fill=\"#d97706\">Server</text>\n  \n  <!-- Step 1: Initial Request -->\n  <circle cx=\"180\" cy=\"820\" r=\"20\" fill=\"#3b82f6\"/>\n  <text x=\"180\" y=\"827\" font-size=\"14\" text-anchor=\"middle\" fill=\"white\">1</text>\n  <text x=\"180\" y=\"860\" font-size=\"12\" text-anchor=\"middle\" fill=\"#333\">Fetch API / HTTP Client</text>\n  <text x=\"180\" y=\"875\" font-size=\"11\" text-anchor=\"middle\" fill=\"#666\">POST /stream</text>\n  \n  <!-- Arrow 1 -->\n  <path d=\"M 280 830 L 920 830\" stroke=\"#3b82f6\" stroke-width=\"2\" marker-end=\"url(#arrowblue)\"/>\n  <text x=\"600\" y=\"820\" font-size=\"12\" text-anchor=\"middle\" fill=\"#3b82f6\">HTTP/2 Request + Body</text>\n  <text x=\"600\" y=\"835\" font-size=\"11\" text-anchor=\"middle\" fill=\"#666\">Transfer-Encoding: chunked</text>\n  \n  <!-- Step 2: Bidirectional Stream -->\n  <circle cx=\"1020\" cy=\"900\" r=\"20\" fill=\"#d97706\"/>\n  <text x=\"1020\" y=\"907\" font-size=\"14\" text-anchor=\"middle\" fill=\"white\">2</text>\n  <text x=\"1020\" y=\"940\" font-size=\"12\" text-anchor=\"middle\" fill=\"#333\">Mở Stream</text>\n  <text x=\"1020\" y=\"955\" font-size=\"11\" text-anchor=\"middle\" fill=\"#666\">HTTP/2 Multiplexing</text>\n  \n  <!-- Bidirectional connection -->\n  <rect x=\"400\" y=\"980\" width=\"400\" height=\"40\" fill=\"#d1ecf1\" stroke=\"#0c5460\" stroke-width=\"1\" rx=\"5\"/>\n  <text x=\"600\" y=\"1000\" font-size=\"12\" text-anchor=\"middle\" fill=\"#0c5460\">Stream hai chiều (Bidirectional)</text>\n  <text x=\"600\" y=\"1015\" font-size=\"11\" text-anchor=\"middle\" fill=\"#0c5460\">Multiplexing - nhiều stream/connection</text>\n  \n  <!-- Step 3: Client sends data -->\n  <circle cx=\"180\" cy=\"1050\" r=\"20\" fill=\"#3b82f6\"/>\n  <text x=\"180\" y=\"1057\" font-size=\"14\" text-anchor=\"middle\" fill=\"white\">3</text>\n  <text x=\"180\" y=\"1090\" font-size=\"12\" text-anchor=\"middle\" fill=\"#333\">Gửi dữ liệu</text>\n  \n  <path d=\"M 280 1060 L 920 1060\" stroke=\"#9333ea\" stroke-width=\"2\" marker-end=\"url(#arrowpurple)\"/>\n  <text x=\"600\" y=\"1050\" font-size=\"11\" text-anchor=\"middle\" fill=\"#9333ea\">Client → Server: Chunk 1</text>\n  \n  <!-- Step 4: Server processes and responds -->\n  <circle cx=\"1020\" cy=\"1120\" r=\"20\" fill=\"#d97706\"/>\n  <text x=\"1020\" y=\"1127\" font-size=\"14\" text-anchor=\"middle\" fill=\"white\">4</text>\n  <text x=\"1020\" y=\"1160\" font-size=\"12\" text-anchor=\"middle\" fill=\"#333\">Xử lý & Response</text>\n  \n  <!-- Multiple chunks both ways -->\n  <path d=\"M 920 1130 L 280 1130\" stroke=\"#28a745\" stroke-width=\"2\" marker-end=\"url(#arrowgreen)\"/>\n  <text x=\"600\" y=\"1120\" font-size=\"11\" text-anchor=\"middle\" fill=\"#28a745\">Server → Client: Response Chunk 1</text>\n  \n  <path d=\"M 280 1170 L 920 1170\" stroke=\"#9333ea\" stroke-width=\"2\" marker-end=\"url(#arrowpurple)\"/>\n  <text x=\"600\" y=\"1160\" font-size=\"11\" text-anchor=\"middle\" fill=\"#9333ea\">Client → Server: Chunk 2</text>\n  \n  <path d=\"M 920 1210 L 280 1210\" stroke=\"#28a745\" stroke-width=\"2\" marker-end=\"url(#arrowgreen)\"/>\n  <text x=\"600\" y=\"1200\" font-size=\"11\" text-anchor=\"middle\" fill=\"#28a745\">Server → Client: Response Chunk 2</text>\n  \n  <!-- Streamable HTTP Characteristics -->\n  <rect x=\"320\" y=\"1250\" width=\"560\" height=\"90\" fill=\"#e7f3ff\" stroke=\"#0066cc\" stroke-width=\"1\" rx=\"5\"/>\n  <text x=\"600\" y=\"1270\" font-size=\"14\" font-weight=\"bold\" text-anchor=\"middle\" fill=\"#004080\">Đặc điểm Streamable HTTP:</text>\n  <text x=\"340\" y=\"1290\" font-size=\"12\" fill=\"#004080\">• Hai chiều: Client ↔ Server</text>\n  <text x=\"340\" y=\"1310\" font-size=\"12\" fill=\"#004080\">• HTTP/2+ multiplexing, không giới hạn connection</text>\n  <text x=\"340\" y=\"1330\" font-size=\"12\" fill=\"#004080\">• Hỗ trợ backpressure, flow control tốt hơn</text>\n  \n  <!-- Arrow definitions -->\n  <defs>\n    <marker id=\"arrowblue\" markerWidth=\"10\" markerHeight=\"7\" refX=\"9\" refY=\"3.5\" orient=\"auto\" markerUnits=\"strokeWidth\">\n      <polygon points=\"0 0, 10 3.5, 0 7\" fill=\"#3b82f6\"/>\n    </marker>\n    <marker id=\"arrowgreen\" markerWidth=\"10\" markerHeight=\"7\" refX=\"9\" refY=\"3.5\" orient=\"auto\" markerUnits=\"strokeWidth\">\n      <polygon points=\"0 0, 10 3.5, 0 7\" fill=\"#28a745\"/>\n    </marker>\n    <marker id=\"arrowpurple\" markerWidth=\"10\" markerHeight=\"7\" refX=\"9\" refY=\"3.5\" orient=\"auto\" markerUnits=\"strokeWidth\">\n      <polygon points=\"0 0, 10 3.5, 0 7\" fill=\"#9333ea\"/>\n    </marker>\n  </defs>\n</svg>"}
	],
	"edges":[]
}